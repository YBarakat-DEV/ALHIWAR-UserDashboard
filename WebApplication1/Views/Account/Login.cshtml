@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Login</title>
    <link href="~/AdminLTE/dist/css/adminlte.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
            body {
                background: #0f172a;
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .login-box {
                width: 400px;
                background: white;
                padding: 30px;
                border-radius: 15px;
            }
    </style>
</head>
<body>

    <div class="login-box">
        <h3 class="text-center">Omar CMS Login</h3>
        <h3 class="text-center">ya rab 2000 dolar</h3>
        <h3 class="text-center">ya rab 3000 dolar</h3>
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form method="post">
            <input name="username" class="form-control mb-3" placeholder="Username" />
            <input name="password" type="password" class="form-control mb-3" placeholder="Password" />

            <button class="btn btn-danger w-100">Login</button>
        </form>
    </div>

</body>
</html>